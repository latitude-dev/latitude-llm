# ================================================================
# Latitude Infrastructure
# These are consumed directly by the Docker containers.
# ================================================================

# Postgres
POSTGRES_USER=latitude
POSTGRES_PASSWORD=secret
POSTGRES_DB=latitude_development
# Runtime user: a restricted Postgres user subject to RLS (created by docker/init-db.sh)
POSTGRES_RUNTIME_USER=latitude_app
POSTGRES_RUNTIME_PASSWORD=secret

# ClickHouse (Docker init + migration tooling only)
CLICKHOUSE_MIGRATION_URL=clickhouse://localhost:9000
CLICKHOUSE_CLUSTER_ENABLED=false

# Weaviate
API_BASED_MODULES_DISABLED=true
ASYNC_INDEXING=true
AUTHENTICATION_ANONYMOUS_ACCESS_ENABLED=false
AUTHENTICATION_APIKEY_ALLOWED_KEYS=secret
AUTHENTICATION_APIKEY_ENABLED=true
AUTHENTICATION_APIKEY_USERS=latitude
AUTHORIZATION_ENABLE_RBAC=true
AUTHORIZATION_RBAC_ROOT_USERS=latitude
AUTOSCHEMA_ENABLED=false
CLUSTER_HOSTNAME=latitude
DEFAULT_QUANTIZATION=none
DEFAULT_VECTORIZER_MODULE=none
DISABLE_TELEMETRY=true
ENABLE_MODULES= # Note: leave blank
LOG_LEVEL=warning
PERSISTENCE_DATA_PATH=/var/lib/weaviate
QUERY_DEFAULTS_LIMIT=25
QUERY_MAXIMUM_RESULTS=1000

# Node
NODE_ENV=development

# ================================================================
# Latitude Application
# All application env vars are prefixed with LAT_.
# ================================================================

# ClickHouse (also consumed by Docker clickhouse container via env_file)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=latitude
CLICKHOUSE_PASSWORD=secret
CLICKHOUSE_DB=latitude_development

# Application database (runtime user — subject to RLS)
LAT_DATABASE_URL=postgres://latitude_app:secret@localhost:5432/latitude_development
LAT_PG_POOL_MAX=20
LAT_PG_IDLE_TIMEOUT_MS=30000
LAT_PG_CONNECT_TIMEOUT_MS=10000
# Admin database (superuser — bypasses RLS; used by drizzle-kit, seeds, and cross-org runtime queries)
LAT_ADMIN_DATABASE_URL=postgres://latitude:secret@localhost:5432/latitude_development

# Vector database
LAT_WEAVIATE_URL= # Optional: use Weaviate cloud
LAT_WEAVIATE_API_KEY=secret
LAT_WEAVIATE_HOST=0.0.0.0
LAT_WEAVIATE_HTTP_PORT=8099
LAT_WEAVIATE_GRPC_PORT=50051

# Voyage AI (embeddings and reranking)
LAT_VOYAGE_API_KEY=

# Cache
LAT_REDIS_HOST=localhost
LAT_REDIS_PORT=6379

# BullMQ Queue
LAT_BULLMQ_HOST=localhost
LAT_BULLMQ_PORT=6380
# LAT_BULLMQ_PASSWORD=

# Temporal — local docker-compose: plain gRPC, no API key
LAT_TEMPORAL_ADDRESS=localhost:7233
LAT_TEMPORAL_NAMESPACE=default
LAT_TEMPORAL_TASK_QUEUE=latitude-workflows
# Temporal Cloud: use regional host, your namespace id, and an API key from the Cloud UI
# LAT_TEMPORAL_ADDRESS=eu-central-1.aws.api.temporal.io:7233
# LAT_TEMPORAL_NAMESPACE=your-namespace.account-id
# LAT_TEMPORAL_API_KEY=
# LAT_WORKFLOWS_HEALTH_PORT=9091
# Local UI (docker compose temporal-ui): http://localhost:8233

# Object Storage
LAT_STORAGE_DRIVER=fs
# Absolute path in your laptop
LAT_STORAGE_FS_ROOT=/Users/YOUR_NAME/path/to/latitude/storage
# LAT_STORAGE_S3_BUCKET=latitude-spans
# LAT_STORAGE_S3_REGION=us-east-1
# LAT_STORAGE_S3_ACCESS_KEY_ID=your-access-key
# LAT_STORAGE_S3_SECRET_ACCESS_KEY=your-secret-key
# LAT_STORAGE_S3_ENDPOINT=https://s3.amazonaws.com

# Ports and URLs
LAT_WEB_URL=http://localhost:3000
LAT_WEB_PORT=3000
LAT_API_URL=http://localhost:3001
LAT_API_PORT=3001
LAT_INGEST_URL=http://localhost:3002
LAT_INGEST_PORT=3002
# Per project+API key trace ingest burst limits
# LAT_INGEST_TRACE_RATE_LIMIT_MAX_REQUESTS=600
# LAT_INGEST_TRACE_RATE_LIMIT_MAX_BYTES=67108864
# LAT_INGEST_TRACE_RATE_LIMIT_WINDOW_SECONDS=60
# LAT_WORKERS_HEALTH_PORT=9090

# Master encryption key (32-byte hex key for AES-256-GCM)
LAT_MASTER_ENCRYPTION_KEY=75d697b90c1e46c13bd7f7343ab2b9a9e430cdcda05d47f055e1523d54d5409b

# AI providers (Amazon Bedrock)
LAT_AWS_REGION=eu-central-1
# LAT_AWS_ACCESS_KEY_ID=
# LAT_AWS_SECRET_ACCESS_KEY=
# LAT_AWS_SESSION_TOKEN=
# LAT_AWS_BEARER_TOKEN_BEDROCK=
# LAT_OPENAI_API_KEY=
# LAT_ANTHROPIC_API_KEY=

# GEPA optimizer (optional overrides; local dev auto-detects packages/platform/op-gepa/python/.venv when present)
# LAT_GEPA_PYTHON_ROOT=/Users/YOUR_NAME/src/latitude-v2/packages/platform/op-gepa/python
# LAT_GEPA_PYTHON_EXECUTABLE=/Users/YOUR_NAME/src/latitude-v2/packages/platform/op-gepa/python/.venv/bin/python
# LAT_GEPA_SEED=310700

# Better Auth
LAT_BETTER_AUTH_SECRET=bd84f86b2cc1011da17d68e5a808f873d30383bc3717c4e770629e4f3b55b7da
LAT_BETTER_AUTH_URL=http://localhost:3001

# Bot protection: Cloudflare Turnstile (optional)
# LAT_TURNSTILE_SECRET_KEY=0x...
# VITE_LAT_TURNSTILE_SITE_KEY=0x...

# Web / CORS
LAT_TRUSTED_ORIGINS=http://localhost:3000
LAT_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Email: Mailpit (local development - default)
LAT_MAILPIT_HOST=localhost
LAT_MAILPIT_PORT=1025
LAT_MAILPIT_FROM=noreply@latitude.local

# Email: Mailgun (optional)
# LAT_MAILGUN_API_KEY=key-xxx
# LAT_MAILGUN_DOMAIN=mg.yourdomain.com
# LAT_MAILGUN_FROM=noreply@yourdomain.com
# LAT_MAILGUN_REGION=us

# Email: SMTP (optional, e.g. SendGrid SMTP, AWS SES)
# LAT_SMTP_HOST=smtp.sendgrid.net
# LAT_SMTP_PORT=587
# LAT_SMTP_USER=apikey
# LAT_SMTP_PASS=your-sendgrid-api-key
# LAT_SMTP_FROM=noreply@yourdomain.com

# Email: SendGrid API (optional)
# LAT_SENDGRID_API_KEY=SG.xxx
# LAT_SENDGRID_FROM=noreply@yourdomain.com

# OAuth Providers (optional)
# LAT_GOOGLE_CLIENT_ID=your-google-client-id
# LAT_GOOGLE_CLIENT_SECRET=your-google-client-secret
# LAT_GITHUB_CLIENT_ID=your-github-client-id
# LAT_GITHUB_CLIENT_SECRET=your-github-client-secret

# Stripe (optional)
# LAT_STRIPE_SECRET_KEY=sk_test_xxx
# LAT_STRIPE_WEBHOOK_SECRET=whsec_xxx

# Frontend
# LAT_WEB_BUNDLE_ANALYZE=false
VITE_LAT_API_URL=http://localhost:3001/v1
VITE_LAT_WEB_URL=http://localhost:3000

# Observability (OTEL via Datadog Agent Sidecar)
# Enable OTEL startup in services that call initializeObservability
# LAT_OBSERVABILITY_ENABLED=false
# Deployment environment tag (defaults to NODE_ENV when omitted)
# LAT_OBSERVABILITY_ENVIRONMENT=development
# Optional default service override; each app passes its own serviceName
# LAT_OBSERVABILITY_SERVICE_NAME=
# OTLP traces endpoint (apps send to Datadog Agent sidecar)
# LAT_OBSERVABILITY_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# Optional comma-separated OTLP headers (key=value,key2=value2)
# LAT_OBSERVABILITY_OTLP_HEADERS=

# PostHog (optional — analytics + session recordings)
# When LAT_POSTHOG_API_KEY is unset, backend event capture no-ops.
# When VITE_LAT_POSTHOG_KEY is unset, the frontend SDK is not loaded.
# LAT_POSTHOG_API_KEY=phc_xxx
# LAT_POSTHOG_HOST=https://eu.i.posthog.com
# VITE_LAT_POSTHOG_KEY=phc_xxx
# VITE_LAT_POSTHOG_HOST=https://eu.i.posthog.com
