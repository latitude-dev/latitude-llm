type Metadata = {
  duration: number;
  usage: {
    input: number;
    output: number;
    reasoning: number;
    cacheRead: number;
    cacheWrite: number;
  }
  cost: number;
  turns: number;
  ...
}

async function evaluate(conversation: Message[], metadata: Metadata) {
  const tools = conversation.filter(m => m.role === "assistant" && m.content.type === "tool_call").map(m => m.content);
  
  const reasoningIdx = tools.findIndex(t => t.name === "reasoning");
  const answerIdx = tools.findIndex(t => t.name === "answer");
  if (reasoningIdx === -1 || answerIdx === -1 || reasoningIdx > answerIdx) {
    return Failed(2%, '"reasoning" tool must be called before "answer" tool')
  }

  const cites = tools.filter(t => t.name === "cite")
  if (cites.length < 3) {
    return Failed(2%, 'you have to cite at least 3 sources')
  }

  const question = conversation.at(0)?.content.text;
  if (!question) {
    throw new Error('question is required')
  }

  const answer = conversation.at(-1)?.content.text;
  if (!answer) {
    return Failed(2%, 'you have to answer the question')
  }

  if (metadata.usage.output > 1000) {
    return Failed(33%, 'your answer is too long, please be concise and to the point, it should be no more than 1000 tokens')
  }

  const {correct, feedback} = await llm(`
Did the assistant answer the question correctly given the citations?

Question: ${question}
Answer: ${answer}
Citations: ${cites.map(c => c.content).join('\n')}
`, {
  model: "gpt-4o",
  temperature: 0,
  maxTokens: 1000,
  schema: z.object({
    correct: z.boolean(),
    feedback: z.string(),
  }),
})

  if (correct) {
    if (cites.length < 5) {
      return Passed(50%, "You have answered correctly but you should have used more sources")
    }

    return Passed(100%, "You have answered correctly!")
  }


  const {correction} = await llm(`
Given the original answer and the feedback from the evaluation, give a corrected answer.

Question: ${question}
Answer: ${answer}
Feedback: ${feedback}
`, {
  model: "gpt-4o",
  temperature: 0,
  maxTokens: 1000,
  schema: z.object({
    correction: z.string(),
  }),
})

  return Failed(0%, `
You have answered incorrecly. An example of a correct answer is:
${correction}
`)
}

