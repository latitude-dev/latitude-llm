{
  "name": "@app/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "dev": "tsx watch src/server.ts",
    "check": "biome check src",
    "format": "biome format --write src && biome check --fix src",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir src",
    "openapi:emit": "tsx scripts/emit-openapi.ts"
  },
  "dependencies": {
    "@clickhouse/client": "catalog:",
    "@domain/annotations": "workspace:*",
    "@domain/api-keys": "workspace:*",
    "@domain/organizations": "workspace:*",
    "@domain/projects": "workspace:*",
    "@domain/queue": "workspace:*",
    "@domain/scores": "workspace:*",
    "@domain/shared": "workspace:*",
    "@domain/spans": "workspace:*",
    "@hono/node-server": "catalog:",
    "@hono/otel": "^1.1.1",
    "@hono/swagger-ui": "^0.5.0",
    "@hono/zod-openapi": "^1.2.4",
    "@platform/ai": "workspace:*",
    "@platform/ai-voyage": "workspace:*",
    "@platform/api-key-auth": "workspace:*",
    "@platform/cache-redis": "workspace:*",
    "@platform/db-clickhouse": "workspace:*",
    "@platform/db-postgres": "workspace:*",
    "@platform/env": "workspace:*",
    "@platform/queue-bullmq": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/utils": "workspace:*",
    "effect": "catalog:",
    "hono": "catalog:",
    "tsx": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@domain/evaluations": "workspace:*",
    "@domain/issues": "workspace:*",
    "@platform/testkit": "workspace:*",
    "tsdown": "catalog:"
  }
}
