{
  "name": "@app/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "NODE_OPTIONS='--localstorage-file=.localstorage' tsx watch src/server.ts",
    "check": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "check:fix": "biome check --fix src"
  },
  "dependencies": {
    "@clickhouse/client": "catalog:",
    "@domain/api-keys": "workspace:*",
    "@domain/email": "workspace:*",
    "@domain/organizations": "workspace:*",
    "@domain/projects": "workspace:*",
    "@domain/shared": "workspace:*",
    "@hono/node-server": "catalog:",
    "@platform/auth-better": "workspace:*",
    "@platform/cache-redis": "workspace:*",
    "@platform/db-clickhouse": "workspace:*",
    "@platform/db-postgres": "workspace:*",
    "@platform/email-nodemailer": "workspace:*",
    "@platform/env": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/utils": "workspace:*",
    "@types/pg": "catalog:",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "dotenv": "catalog:",
    "effect": "catalog:",
    "hono": "catalog:",
    "pg": "catalog:",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.3.15",
    "@platform/testkit": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "drizzle-kit": "catalog:"
  }
}
