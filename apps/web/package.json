{
  "name": "@app/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--no-experimental-webstorage\" vite",
    "build": "vite build && node ./scripts/repair-server-sourcemaps.mjs",
    "build:analyze": "LAT_WEB_BUNDLE_ANALYZE=true vite build && node ./scripts/repair-server-sourcemaps.mjs",
    "check:bundle-size": "node ./scripts/check-bundle-size.mjs",
    "start": "node --no-experimental-webstorage .output/server/index.mjs",
    "check": "biome check src",
    "format": "biome format --write src && biome check --fix src",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir src"
  },
