{
  "name": "@app/workflows",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/server.ts",
    "triggerWorkflowTest": "tsx src/trigger-test.ts",
    "check": "biome check src",
    "format": "biome format --write src && biome check --fix src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@domain/shared": "workspace:*",
    "@domain/issues": "workspace:*",
    "@domain/scores": "workspace:*",
    "@platform/ai-voyage": "workspace:*",
    "@platform/cache-redis": "workspace:*",
    "@platform/db-clickhouse": "workspace:*",
    "@platform/db-postgres": "workspace:*",
    "@platform/db-weaviate": "workspace:*",
    "@platform/env": "workspace:*",
    "@platform/workflows-temporal": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/utils": "workspace:*",
    "@temporalio/workflow": "catalog:",
    "@temporalio/worker": "catalog:",
    "effect": "catalog:",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "tsup": "^8.0.0"
  }
}
