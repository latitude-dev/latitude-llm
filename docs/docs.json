{
  "$schema": "https://mintlify.com/schema.json",
  "theme": "mint",
  "name": "Latitude Docs",
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://latitude.so"
  },
  "colors": {
    "primary": "#0080FF",
    "light": "#3399FF",
    "dark": "#0066CC"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter",
      "weight": 600
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "styling": {
    "eyebrow": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "v2/getting-started/introduction",
          "v2/getting-started/quick-start-dev",
          "v2/getting-started/quick-start-pm"
        ]
      },
      {
        "group": "Telemetry",
        "pages": [
          "v2/telemetry/overview",
          {
            "group": "Providers",
            "pages": [
              "v2/telemetry/providers/openai",
              "v2/telemetry/providers/anthropic",
              "v2/telemetry/providers/gemini",
              "v2/telemetry/providers/azure",
              "v2/telemetry/providers/amazon-bedrock",
              "v2/telemetry/providers/google-ai-platform",
              "v2/telemetry/providers/vertex-ai",
              "v2/telemetry/providers/groq",
              "v2/telemetry/providers/mistral",
              "v2/telemetry/providers/ollama",
              "v2/telemetry/providers/cohere",
              "v2/telemetry/providers/together-ai",
              "v2/telemetry/providers/litellm",
              "v2/telemetry/providers/replicate",
              "v2/telemetry/providers/sagemaker",
              "v2/telemetry/providers/watsonx",
              "v2/telemetry/providers/aleph-alpha",
              "v2/telemetry/providers/transformers"
            ]
          },
          {
            "group": "Frameworks",
            "pages": [
              "v2/telemetry/frameworks/vercel-ai-sdk",
              "v2/telemetry/frameworks/langchain",
              "v2/telemetry/frameworks/llamaindex",
              "v2/telemetry/frameworks/crewai",
              "v2/telemetry/frameworks/dspy",
              "v2/telemetry/frameworks/haystack"
            ]
          }
        ]
      },
      {
        "group": "Observability",
        "pages": [
          "v2/observability/overview",
          "v2/observability/traces",
          "v2/observability/sessions"
        ]
      },
      {
        "group": "Evaluations",
        "pages": [
          "v2/evaluations/overview",
          "v2/evaluations/triggers",
          "v2/evaluations/alignment"
        ]
      },
      {
        "group": "Annotations",
        "pages": [
          "v2/annotations/overview",
          "v2/annotations/annotation-queues",
          "v2/annotations/inline-annotations"
        ]
      },
      {
        "group": "Scores",
        "pages": [
          "v2/scores/overview",
          "v2/scores/analytics"
        ]
      },
      {
        "group": "Issues",
        "pages": [
          "v2/issues/overview",
          "v2/issues/management"
        ]
      },
      {
        "group": "Simulations",
        "pages": ["v2/simulations/overview"]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/latitude-dev/latitude-llm",
      "slack": "https://join.slack.com/t/trylatitude/shared_invite/zt-35wu2h9es-N419qlptPMhyOeIpj3vjzw"
    }
  }
}
