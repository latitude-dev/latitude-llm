            "pages": [
              "telemetry/claude-code",
              "telemetry/openclaw"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "observability/features/duration",
              "observability/features/environments",
              "observability/filters",
              "observability/features/log-levels",
              "observability/features/metadata",
              "observability/features/percentile-cohorts",
              "observability/features/releases-versioning",
              "observability/features/sampling",
              "observability/sessions",
