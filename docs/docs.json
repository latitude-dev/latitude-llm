{
  "$schema": "https://mintlify.com/schema.json",
  "theme": "mint",
  "name": "Latitude Docs",
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://latitude.so"
  },
  "colors": {
    "primary": "#0080FF",
    "light": "#3399FF",
    "dark": "#0066CC"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter",
      "weight": 600
    }
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "styling": {
    "eyebrow": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/latitude-dev/latitude-llm"
        },
        {
          "anchor": "YouTube",
          "icon": "youtube",
          "href": "https://www.youtube.com/@trylatitude"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "telemetry/start-tracing",
          "getting-started/how-to-use-latitude"
        ]
      },
      {
        "group": "Observability",
        "pages": [
          "telemetry/start-tracing",
          {
            "group": "SDKs",
            "pages": [
              "telemetry/typescript",
              "telemetry/python",
              "telemetry/otel-exporter"
            ]
          },
          {
            "group": "Providers",
            "pages": [
              "telemetry/providers/openai",
              "telemetry/providers/anthropic",
              "telemetry/providers/azure",
              "telemetry/providers/amazon-bedrock",
              "telemetry/providers/google-ai-platform",
              "telemetry/providers/vertex-ai",
              "telemetry/providers/cohere",
              "telemetry/providers/together-ai"
            ]
          },
          {
            "group": "Frameworks",
            "pages": [
              "telemetry/frameworks/vercel-ai-sdk",
              "telemetry/frameworks/openai-agents",
              "telemetry/frameworks/langchain",
              "telemetry/frameworks/llamaindex",
              "telemetry/frameworks/mastra"
            ]
          },
