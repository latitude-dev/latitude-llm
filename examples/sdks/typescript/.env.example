# Base URL of the Latitude API. Point at your local dev server to iterate
# against uncommitted route changes; flip to https://api.latitude.so when
# you want to exercise production.
LATITUDE_API_BASE_URL=http://localhost:3001

# Organization-scoped API key (`Authorization: Bearer <token>`). Generate
# one from the Latitude web UI or the `POST /v1/organizations/:orgId/api-keys`
# endpoint. Never commit the real token.
LATITUDE_API_KEY=

# Organization that owns the project. CUID (database id).
LATITUDE_ORGANIZATION_ID=

# Target project, identified by its slug (human-readable), not the CUID.
# The slug is what you see in the Latitude URL, e.g. `my-project-abc123`.
LATITUDE_PROJECT_SLUG=

# An existing trace in that project. 32-char hex OpenTelemetry trace id.
# Required for `create-annotation.ts` (the by-id flow).
LATITUDE_TRACE_ID=

# Optional: session id used by `create-annotation-by-filter.ts` to resolve a
# trace via filter instead of by explicit id.
LATITUDE_SESSION_ID=
