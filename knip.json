{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {},
    "apps/api": {
      "project": ["src/**/*.ts"]
    },
    "apps/ingest": {
      "project": ["src/**/*.ts"]
    },
    "apps/workers": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@temporalio/worker"]
    },
    "apps/workflows": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/workflows/**/*.ts"],
      "ignoreDependencies": ["@temporalio/worker"]
    },
    "apps/web": {
      "entry": ["src/router.tsx", "src/start.ts", "src/routes/**/*.tsx"],
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignoreDependencies": ["@temporalio/client"]
    },
    "infra": {
      "entry": [],
      "project": []
    },
    "packages/domain/email": {
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignoreDependencies": ["@react-email/preview-server"]
    },
    "packages/domain/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/platform/db-postgres": {
      "entry": ["src/seeds/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/platform/db-weaviate": {
      "project": ["src/**/*.ts"]
    },
    "packages/platform/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/sdk/typescript": {
      "entry": [],
      "project": [],
      "ignoreBinaries": ["tsup"]
    },
    "examples/sdks/typescript": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreBinaries": ["tsx"],
      "ignoreDependencies": ["tsx"]
    },
    "packages/ui": {
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "packages/vitest-config": {
      "project": ["**/*.ts"]
    },
    "packages/tsconfig": {
      "entry": [],
      "project": []
    },
    "packages/telemetry/typescript": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/constants/**/*.ts"],
      "ignoreDependencies": [
        "@ai-sdk/openai",
        "@anthropic-ai/sdk",
        "@aws-sdk/client-bedrock-runtime",
        "@google-cloud/vertexai",
        "@langchain/openai",
        "ai",
        "cohere-ai",
        "langchain",
        "llamaindex",
        "openai"
      ]
    }
  },
  "ignoreBinaries": ["tmuxinator", "pulumi"],
  "ignoreDependencies": ["@pulumi/awsx", "@pulumi/aws", "@pulumi/pulumi", "@pulumi/random", "fern-api"]
}
