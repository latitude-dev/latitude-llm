{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {},
    "apps/api": {
      "entry": ["src/openapi/pagination.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/ingest": {
      "project": ["src/**/*.ts"]
    },
    "apps/workers": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@temporalio/worker"]
    },
    "apps/workflows": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/workflows/**/*.ts"],
      "ignoreDependencies": ["@temporalio/worker"]
    },
    "apps/web": {
      "entry": ["src/router.tsx", "src/start.ts", "src/routes/**/*.tsx"],
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignore": [
        "src/domains/feature-flags/feature-flags.collection.ts",
        "src/domains/feature-flags/feature-flags.functions.ts"
      ],
      "ignoreDependencies": ["@temporalio/client"]
    },
    "infra": {
      "entry": [],
      "project": []
    },
    "packages/domain/email": {
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignoreDependencies": []
    },
    "packages/domain/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/platform/db-postgres": {
      "entry": ["src/seeds/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/platform/db-weaviate": {
      "project": ["src/**/*.ts"]
    },
    "packages/platform/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/sdk/typescript": {
      "entry": [],
      "project": [],
      "ignoreBinaries": []
    },
    "examples/sdks/typescript": {
      "entry": ["src/**/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreBinaries": [],
      "ignoreDependencies": []
    },
    "packages/ui": {
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "packages/vitest-config": {
      "project": ["**/*.ts"]
    },
    "packages/tsconfig": {
      "entry": [],
      "project": []
    },
    "packages/telemetry/typescript": {
      "entry": ["examples/**/*.ts"],
      "project": ["src/**/*.ts", "examples/**/*.ts"],
      "ignore": ["src/constants/**/*.ts"],
      "ignoreDependencies": ["@sentry/node", "dd-trace", "together-ai"]
    },
    "tools/ai-benchmarks": {
      "entry": ["src/scripts/**/*.ts"],
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    }
  },
  "ignoreBinaries": ["tmuxinator", "pulumi"],
  "ignoreDependencies": ["@pulumi/awsx", "@pulumi/aws", "@pulumi/pulumi", "@pulumi/random", "fern-api"]
}
