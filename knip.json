{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {},
    "apps/api": {
      "project": ["src/**/*.ts"]
    },
    "apps/ingest": {
      "project": ["src/**/*.ts"]
    },
    "apps/workers": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@temporalio/worker"]
    },
    "apps/workflows": {
      "project": ["src/**/*.ts"],
      "ignore": ["src/workflows/**/*.ts"],
      "ignoreDependencies": ["@temporalio/worker"]
    },
    "apps/web": {
      "entry": ["src/router.tsx", "src/start.ts", "src/routes/**/*.tsx"],
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignoreDependencies": ["@domain/annotations", "@domain/scores"]
    },
    "infra": {
      "entry": [],
      "project": []
    },
    "packages/domain/email": {
      "project": ["src/**/*.ts", "src/**/*.tsx"],
      "ignoreDependencies": ["@react-email/preview-server"]
    },
    "packages/domain/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/platform/db-postgres": {
      "entry": ["src/seeds/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/platform/db-weaviate": {
      "project": ["src/**/*.ts"]
    },
    "packages/platform/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "packages/vitest-config": {
      "project": ["**/*.ts"]
    },
    "packages/tsconfig": {
      "entry": [],
      "project": []
    }
  },
  "ignoreBinaries": ["tmuxinator", "pulumi"],
  "ignoreDependencies": ["@pulumi/awsx", "@pulumi/aws", "@pulumi/pulumi", "@pulumi/random"],
  "ignoreIssues": {
    "packages/domain/email/src/templates/**/EmailTemplate.tsx": ["exports", "duplicates"],
    "apps/web/src/domains/annotations/annotations.collection.ts": ["files"],
    "apps/web/src/domains/annotations/annotations.functions.ts": ["files"]
  },
  "tags": ["-knipignore"]
}
