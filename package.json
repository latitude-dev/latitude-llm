{
  "name": "latitude-llm",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "turbo check",
    "format": "turbo format",
    "tmux": "tmuxinator start .",
    "typecheck": "turbo typecheck",
    "test": "pnpm test:db:setup && turbo test",
    "test:db:setup": "pnpm --filter @platform/db-postgres db:test:setup",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:fix:files": "knip --fix-type files --allow-remove-files"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@effect/language-service": "^0.77.0",
    "@types/node": "catalog:",
    "knip": "^5.85.0",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=25"
  },
  "version": "0.0.1"
}
