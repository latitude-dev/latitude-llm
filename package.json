{
  "name": "latitude-llm",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "docs": "cd docs && mintlify dev",
    "tc": "turbo tc",
    "prettier": "prettier --write \"**/*.{ts,tsx,md}\" --ignore-path .prettierrcignore",
    "prettier:check": "prettier --check \"**/*.{ts,tsx,md}\" --ignore-path .prettierrcignore",
    "test": "turbo test",
    "catchup": "pnpm i && pnpm build --filter=\"./packages/**/*\" && pnpm --filter \"@latitude-data/core\" db:migrate"
  },
  "devDependencies": {
    "@babel/parser": "^7.26.10",
    "@types/node": "^22.13.10",
    "eslint": "^8.57.1",
    "glob": "^11.0.1",
    "mintlify": "4.0.233",
    "prettier": "^3.5.3",
    "recast": "^0.23.11",
    "turbo": "^2.4.4",
    "tsx": "^4.16.2",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@9.8.0+sha512.8e4c3550fb500e808dbc30bb0ce4dd1eb614e30b1c55245f211591ec2cdf9c611cabd34e1364b42f564bd54b3945ed0f49d61d1bbf2ec9bd74b866fcdc723276",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": ">=18.x",
        "react-dom": ">=18.x",
        "eslint": ">=8.x"
      }
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.6.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable": "^3.0.5",
    "react-textarea-autosize": "^8.5.7",
    "recharts": "2.13.0-alpha.5",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "use-debounce": "^10.0.4",
    "vue": "^3.4.38",
    "zustand": "^4.5.6"
  },
  "optionalDependencies": {
    "svelte": "^4.2.19",
    "vue": "^3.5.13"
  },
  "version": "0.0.1"
