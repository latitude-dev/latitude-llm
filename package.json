{
  "name": "latitude-llm",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "turbo check",
    "hooks": "node ./scripts/setup-git-hooks.mjs",
    "format": "turbo format",
    "tmux": "tmuxinator start .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:fix:files": "knip --fix-type files --allow-remove-files",
    "clean": "node ./scripts/clean-repo.mjs",
    "catchup": "pnpm install && pnpm --filter \"@platform/db-postgres\" pg:migrate && pnpm --filter \"@platform/db-clickhouse\" ch:up && pnpm --filter \"@platform/db-weaviate\" wv:migrate && pnpm build",
    "db:reset": "pnpm --filter \"@platform/db-postgres\" pg:reset && pnpm --filter \"@platform/db-clickhouse\" ch:reset",
    "seed": "pnpm --filter \"@platform/db-postgres\" pg:seed && pnpm --filter \"@platform/db-clickhouse\" ch:seed && pnpm --filter \"@platform/db-weaviate\" wv:seed",
    "prepare": "pnpm hooks && effect-language-service patch"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@effect/language-service": "^0.84.2",
    "@types/node": "catalog:",
    "knip": "^6.1.0",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=25"
  },
  "version": "0.0.1",
  "pnpm": {
    "overrides": {
      "@ai-sdk/provider": "4.0.0-beta.7",
      "drizzle-orm": "1.0.0-beta.15-859cf75",
      "tslib": "2.8.1"
    }
  }
}