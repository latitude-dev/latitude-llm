{
  "name": "@domain/alerts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "check": "biome check src",
    "format": "biome format --write src && biome check --fix src",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir src"
  },
  "dependencies": {
    "@domain/events": "workspace:*",
    "@domain/shared": "workspace:*",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "vitest": "catalog:"
  }
}
