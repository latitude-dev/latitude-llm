{
  "name": "@domain/evaluations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./constants": "./src/constants.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "biome check src",
    "format": "biome format --write src && biome check --fix src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir src"
  },
  "dependencies": {
    "@domain/ai": "workspace:*",
    "@domain/events": "workspace:*",
    "@domain/models": "workspace:*",
    "@domain/optimizations": "workspace:*",
    "@domain/scores": "workspace:*",
    "@domain/shared": "workspace:*",
    "@domain/spans": "workspace:*",
    "effect": "catalog:",
    "zod": "catalog:"
  }
}
