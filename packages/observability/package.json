{
  "name": "@repo/observability",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "biome check src",
    "format": "biome format --write src",
