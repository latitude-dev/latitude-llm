{
  "name": "@platform/db-clickhouse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "ch:create": "bash clickhouse/scripts/create.sh",
    "ch:up": "bash clickhouse/scripts/up.sh",
    "ch:down": "bash clickhouse/scripts/down.sh",
    "ch:status": "bash clickhouse/scripts/status.sh",
    "ch:drop": "bash clickhouse/scripts/drop.sh",
    "ch:fix": "bash clickhouse/scripts/fix.sh",
    "ch:reset": "bash clickhouse/scripts/reset.sh",
    "ch:connect": "bash clickhouse/scripts/connect.sh",
    "ch:schema:dump": "bash clickhouse/scripts/dump-schema.sh",
    "ch:seed": "node --import tsx src/seeds/run.ts",
    "check": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "check:fix": "biome check --fix src"
  },
  "dependencies": {
    "@clickhouse/client": "catalog:",
    "@domain/datasets": "workspace:*",
    "@domain/shared": "workspace:*",
    "@domain/spans": "workspace:*",
    "@platform/env": "workspace:*",
    "@repo/utils": "workspace:*",
    "effect": "catalog:",
    "rosetta-ai": "catalog:"
  },
  "devDependencies": {
    "@platform/db-postgres": "workspace:*",
    "@platform/testkit": "workspace:*",
    "dotenv": "catalog:",
    "tsx": "catalog:"
  }
}
