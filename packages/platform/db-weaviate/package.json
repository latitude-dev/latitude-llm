{
  "name": "@platform/db-weaviate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "wv:migrate": "tsx src/migrate.ts",
    "wv:query": "tsx src/scripts/query.ts",
    "wv:seed": "tsx src/seeds/run.ts",
    "check": "biome check src",
    "format": "biome format --write src && biome check --fix src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir src"
  },
  "dependencies": {
    "@domain/issues": "workspace:*",
    "@domain/shared": "workspace:*",
    "@platform/db-postgres": "workspace:*",
    "@platform/env": "workspace:*",
    "effect": "catalog:",
    "weaviate-client": "catalog:"
  },
  "devDependencies": {
    "tsx": "catalog:"
  }
}
