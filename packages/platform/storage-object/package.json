    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "catalog:"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@domain/shared": "workspace:*",
    "@platform/env": "workspace:*",
    "@repo/utils": "workspace:*",
    "effect": "catalog:",
    "flydrive": "^1.2.0"
  }
}
