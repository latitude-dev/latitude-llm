{
  "name": "@platform/storage-object",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/fake-storage-disk.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "biome check src",
