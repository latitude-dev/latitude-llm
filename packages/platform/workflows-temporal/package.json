{
  "name": "@platform/workflows-temporal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker.ts"
  },
  "scripts": {
    "check": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir src",
    "check:fix": "biome check --fix src"
  },
  "dependencies": {
    "@domain/queue": "workspace:*",
    "@opentelemetry/api": "catalog:",
    "@platform/env": "workspace:*",
    "@repo/observability": "workspace:*",
    "@temporalio/activity": "catalog:",
    "@temporalio/client": "catalog:",
    "@temporalio/worker": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@repo/vitest-config": "workspace:*",
    "vitest": "catalog:"
  }
}
