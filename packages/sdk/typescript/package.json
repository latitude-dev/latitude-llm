{
  "name": "@latitude-data/sdk",
  "version": "6.0.0-alpha.0",
  "description": "Official TypeScript SDK for the Latitude API",
  "author": "Latitude Data SL <hello@latitude.so>",
  "license": "MIT",
  "keywords": [
    "AI",
    "Latitude",
    "sdk",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/latitude-dev/latitude-llm/tree/main/packages/sdk/typescript"
  },
  "homepage": "https://github.com/latitude-dev/latitude-llm/tree/main/packages/sdk/typescript#readme",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "echo 'SDK source is Fern-generated \u2014 skipping lint (see fern/README.md)'",
    "format": "echo 'SDK source is Fern-generated \u2014 formatter controlled by the generator'",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir src"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
