{
  "name": "@tools/seeds",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "check": "biome check src",
    "format": "biome format --write src && biome check --fix src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests --dir src",
    "seed:live-monitor": "node --import tsx src/scripts/send-live-monitor.ts"
  },
  "dependencies": {
    "@domain/annotation-queues": "workspace:*",
    "@domain/evaluations": "workspace:*",
    "@domain/shared": "workspace:*",
    "@domain/spans": "workspace:*",
    "@platform/db-postgres": "workspace:*",
    "@platform/env": "workspace:*",
    "effect": "catalog:",
    "tsx": "catalog:"
  }
}
