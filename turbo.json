{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "passThroughEnv": [
        "NODE_ENV",
        "VITE_LAT_API_URL",
        "VITE_LAT_WEB_URL",
        "VITE_LAT_TURNSTILE_SITE_KEY",
        "VITE_LAT_POSTHOG_KEY",
        "VITE_LAT_POSTHOG_HOST"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check": {
      "dependsOn": ["^check"]
    },
    "format": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
